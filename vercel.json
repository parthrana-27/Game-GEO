{
  "version": 2,
  "services": {
    "frontend": {
      "root": "frontend/"
    },
    "backend": {
      "root": "backend/"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "backend",
        "path": "/api/$1"
      }
    },
    {
      "source": "/((?!api/).*)",
      "destination": {
        "service": "frontend",
        "path": "/index.html"
      }
    }
  ]
}
