{
  "name": "streetsight-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspace=frontend",
    "vercel-build": "prisma generate --schema=backend/prisma/schema.prisma && npm run build",
    "db:migrate": "prisma migrate deploy --schema=backend/prisma/schema.prisma",
    "db:seed": "npm run seed --workspace=backend"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
